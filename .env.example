NODE_ENV=development
# Optional: shown on login/dashboard so you know which code build is running (default set in app.js).
# IIMS_BUILD_STAMP=20260422-ui9
PORT=5002
# Default: DO NOT hop to 5003 — if PORT is busy we exit so you never run TWO Node servers by accident
# (different ports = bookmarked :5002 hits OLD code while VS Code shows :5003 with NEW files).
# Set to 1 only if you consciously want legacy "next port" behaviour (e.g. rare multi-instance tests).
IIMS_PORT_FALLBACK=0
FRONTEND_ORIGIN=http://localhost:5002
JWT_SECRET=change-me-very-long-secret
JWT_EXPIRES_IN=1d

DB_HOST=127.0.0.1
DB_PORT=3306
# Docker: host port is shown in Docker Desktop / `docker ps` (this repo's docker-compose uses 3307->3306). DB_PASS must equal MYSQL_ROOT_PASSWORD.
DB_USER=root
DB_PASS=
DB_NAME=iims_school_system
# Dev: first npm start applies sql/schema.sql if the users table is missing (fresh Docker DB).
# IMIS_SKIP_AUTO_SCHEMA=1

DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=1234
SYSTEM_DEVELOPER_USERNAME=952252
SYSTEM_DEVELOPER_PASSWORD=Sheeza@2015

OTP_CHANNEL=console
OTP_EXPIRY_MINUTES=10
PASSWORD_MIN_LENGTH=12
USERNAME_MIN_LENGTH=5
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
OTP_MAX_VERIFY_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=30
LOGIN_JITTER_MAX_MS=350
ACCOUNT_MUTATION_COOLDOWN_SECONDS=5
SYSTEM_DEVELOPER_MAX_ACCOUNTS=50
REQUEST_RATE_WINDOW_MS=900000
RATE_LIMIT_AUTH_LOGIN_MAX=40
RATE_LIMIT_OTP_VERIFY_MAX=80
RATE_LIMIT_PUBLIC_WRITE_MAX=60
RATE_LIMIT_ACCOUNT_MUTATION_MAX=60
MAX_PUBLIC_BODY_BYTES=1048576
MAX_PUBLIC_BODY_KEYS=120
# =============================================================================
# OTP DELIVERY PROVIDERS
# =============================================================================
#
# IMIS supports multiple SMS + email providers and chooses the fastest
# configured one at runtime. Recommended production combination:
#
#   * Email:  SendGrid (HTTP API, ~150 ms latency, cheap, reliable)
#   * SMS:    Africa's Talking (fast for Kenyan numbers, supports MoE shortcodes)
#
# Twilio + raw SMTP are kept as fallbacks if the primary provider fails.
# =============================================================================

# --- Email: SendGrid (preferred) ---
SENDGRID_API_KEY=
SENDGRID_FROM=no-reply@theimis.com
SENDGRID_FROM_NAME=IMIS

# --- Email: SMTP fallback (Gmail / Zoho / etc.) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- SMS: Africa's Talking (preferred for Kenyan numbers) ---
# Set AT_USERNAME=sandbox while testing; switch to your live AT username at launch.
# AT_FROM = your alphanumeric Sender ID (must be approved by AT first).
AT_API_KEY=
AT_USERNAME=sandbox
AT_FROM=IMIS

# --- SMS: Twilio fallback ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_VERIFY_SERVICE_SID=

# OTP dispatch timeout per channel (milliseconds); prevents the HTTP response from stalling
# when an upstream provider is slow or unreachable.
OTP_DISPATCH_TIMEOUT_MS=32000

# --- Provider example values for reference ---
# SendGrid:
#   1. Sign up at sendgrid.com (Free tier = 100/day).
#   2. Settings -> Sender Authentication -> Authenticate Your Domain.
#   3. Settings -> API Keys -> Create API Key with "Full Access" scope.
#   SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxx
#   SENDGRID_FROM=no-reply@theimis.com
#
# Africa's Talking:
#   1. Sign up at africastalking.com.
#   2. Get your API key from Settings -> API Keys.
#   3. Apply for an alphanumeric Sender ID (1-3 day approval).
#   AT_API_KEY=atsk_xxxxxxxxxxxxxxxxxxxxxx
#   AT_USERNAME=your_at_account_username   # or 'sandbox' for testing
#   AT_FROM=IMIS
#
# Gmail SMTP fallback:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=your-gmail@gmail.com
#   SMTP_PASS=app_password_not_real_password  # generated in Google Account settings
#   SMTP_FROM="IMIS <your-gmail@gmail.com>"
#
# Twilio SMS fallback:
#   TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   TWILIO_FROM=+1xxxxxxxxxx

# =============================================================================
# STRICT ROLE DEFAULTS / LEGACY ADMIN
# =============================================================================
# New installs start with ZERO automatic module overrides for ADMIN/HOI/System Admin roles.
# For upgraded databases ONLY, temporarily set IMIS_SEED_EXISTING_ADMIN_MODULE_RIGHTS=1 once and restart Node.
IMIS_SEED_EXISTING_ADMIN_MODULE_RIGHTS=0

# Safer pilot option: grant only the Examination stack (cbc-curriculum-editor, academic-exams, academic-marks)
# to active ADMIN / HOI / SYSTEM_ADMINISTRATOR users that have a real institution_id—independent of the full legacy blast above.
IMIS_SEED_INSTITUTION_EXAM_ACCESS=0
# Same examination stack for TEACHER / SENIOR_TEACHER / HEAD_OF_DEPARTMENT (institution-linked accounts only).
IMIS_SEED_TEACHER_EXAM_ACCESS=0

# Disabled by default — legacy admin/password bootstrap is insecure for pilots.
CREATE_DEFAULT_LEGACY_ADMIN_USER=0

# Non-production OTP console trace — explicit operator opt-in only.
IMIS_CONSOLE_OTP_ON_DISPATCH_FAILURE=0
IMIS_CONSOLE_OTP_ON_FAILURE=0

RATE_LIMIT_PUBLIC_READ_MAX=240
RATE_LIMIT_PUBLIC_ADMISSION_LOOKUP_MAX=60

# Optional absolute URL echoed in applicant emails for one-click Admission Portal loads.
ADMISSION_PUBLIC_BASE_URL=

# Admission applicant uploads — max bytes per file (soft cap ~20MB ceiling in code); max attachments per application row.
# ADMISSION_UPLOAD_MAX_BYTES=6291456
# ADMISSION_UPLOAD_MAX_FILES_PER_REQUEST=12

# Planned infrastructure (exam AI async jobs / rate smoothing): Redis queue — not wired in this codebase yet.
# REDIS_URL=redis://127.0.0.1:6379

# =============================================================================
# OPENAI CBC EXAM STEMS (server-side only — never expose to browsers or Git)
# Never paste secrets into chats, tickets, or client-side code — rotate keys if exposed.
# =============================================================================
OPENAI_API_KEY=
EXAM_OPENAI_MODEL=gpt-4o-mini
EXAM_OPENAI_MAX_CALLS_PER_INSTITUTION_PER_WINDOW=12
EXAM_OPENAI_RATE_LIMIT_WINDOW_MS=600000

# Set to true/1/on to skip blending institution Question Bank MCQs during auto-generation.
EXAM_DISABLE_QUESTION_BANK_MCQ=

# Set to true/1/on to skip blending stems from non-MCQ Question Bank rows in structured (Section-B style) sections during auto-generation.
EXAM_DISABLE_QUESTION_BANK_STRUCTURED=

# Pilot-only: allow PUT edits to learner-facing exam text after serials/QR have been processed (disables tamper-evident freeze).
EXAM_ALLOW_EDIT_AFTER_SERIAL_PROCESS=

# Hide /api/build-info build_stamp + fingerprints from browsers (login + dashboard still show local bundle ids).
IMIS_HIDE_BUILD_STAMP_FROM_CLIENTS=
