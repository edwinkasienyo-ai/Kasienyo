From 846da04cd8635fb64927fcf551de3644a6ee79c6 Mon Sep 17 00:00:00 2001
From: Cursor Agent <cursor-agent@users.noreply.github.com>
Date: Wed, 6 May 2026 17:10:31 +0000
Subject: [PATCH 12/14] Add backend/.env.example template

Documents every env var the backend reads, with sensible defaults that
make the project run on a fresh laptop with zero external services:

- Server: PORT, FRONTEND_ORIGIN
- Database: DB_DIALECT (default sqlite), plus mysql/postgres overrides
- Auth: JWT_SECRET, JWT_EXPIRES_IN, OTP_TTL_MS, EXPOSE_OTP
- Default seeded users: admin / Admin@1234 and sysdev / Sysdev@1234
- Optional Twilio Verify env vars (left commented out)

Also fixes .gitignore so backend/.env.example is committed even though
backend/.env is ignored. The default ignore patterns 'backend/.env.*'
were too greedy; added an explicit '!backend/.env.example' negation
after them.
---
 .gitignore           |  2 ++
 backend/.env.example | 64 ++++++++++++++++++++++++++++++++++++++++++++
 2 files changed, 66 insertions(+)
 create mode 100644 backend/.env.example

diff --git a/.gitignore b/.gitignore
index 0ea3679..f05061e 100644
--- a/.gitignore
+++ b/.gitignore
@@ -4,8 +4,10 @@ imis-frontend/node_modules/
 .env
 .env.*
 !.env.example
+!**/.env.example
 backend/.env
 backend/.env.*
+!backend/.env.example
 imis-frontend/.env.local
 backend/dist/
 backend/database.sqlite
diff --git a/backend/.env.example b/backend/.env.example
new file mode 100644
index 0000000..433dc55
--- /dev/null
+++ b/backend/.env.example
@@ -0,0 +1,64 @@
+# =======================
+# Backend environment template
+# =======================
+#
+# Copy this file to backend/.env and fill in real values.
+# .env is git-ignored, .env.example is committed.
+#
+#   cp backend/.env.example backend/.env
+
+# ---------------------------------------------------------------
+# Server
+# ---------------------------------------------------------------
+PORT=5000
+FRONTEND_ORIGIN=http://localhost:3000
+
+# ---------------------------------------------------------------
+# Database
+# ---------------------------------------------------------------
+# DB_DIALECT can be:
+#   sqlite   (default — zero setup, single file at backend/database.sqlite)
+#   mysql
+#   postgres
+DB_DIALECT=sqlite
+
+# Only used when DB_DIALECT is mysql or postgres:
+DB_HOST=127.0.0.1
+DB_PORT=3306
+DB_USER=root
+DB_PASSWORD=
+DB_NAME=imis
+
+# Only used when DB_DIALECT is sqlite (optional override path):
+# DB_STORAGE=./database.sqlite
+
+# ---------------------------------------------------------------
+# Authentication
+# ---------------------------------------------------------------
+# IMPORTANT: change this in production. Anything 32+ random chars is fine.
+JWT_SECRET=change-me-to-a-long-random-string-please
+JWT_EXPIRES_IN=1d
+
+# OTP TTL in milliseconds (default 600000 = 10 minutes)
+OTP_TTL_MS=600000
+
+# In dev, set EXPOSE_OTP=true so /api/auth/send-otp returns the OTP in
+# the response (no SMS/email needed). Set to false in production.
+EXPOSE_OTP=true
+
+# ---------------------------------------------------------------
+# Default users (seeded on first startup)
+# ---------------------------------------------------------------
+DEFAULT_ADMIN_USERNAME=admin
+DEFAULT_ADMIN_PASSWORD=Admin@1234
+
+DEFAULT_SYSDEV_USERNAME=sysdev
+DEFAULT_SYSDEV_PASSWORD=Sysdev@1234
+
+# ---------------------------------------------------------------
+# Twilio Verify (optional — for real SMS/email OTP)
+# ---------------------------------------------------------------
+# Leave blank in dev; the in-memory dev OTP works without these.
+# TWILIO_SID=
+# TWILIO_AUTH=
+# TWILIO_SERVICE_ID=
