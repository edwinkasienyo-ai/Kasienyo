From 0f05f2f03bbc6443d483e05507fda6c1b1482914 Mon Sep 17 00:00:00 2001
From: Cursor Agent <cursor-agent@users.noreply.github.com>
Date: Wed, 6 May 2026 17:09:28 +0000
Subject: [PATCH 11/13] Add start/dev scripts and nodemon devDependency to
 backend

Previously backend/package.json had only a 'test' script, so 'npm run dev'
exited with 'missing script: dev', and 'npm start' did nothing useful.

Changes:
- Add 'start': node server.js
- Add 'dev': nodemon server.js  (auto-restart on file changes)
- Add nodemon to devDependencies
- Improve description and keywords

After this, the user can:
  cd backend
  npm install
  npm run dev
---
 backend/package.json | 16 +++++++++++++---
 1 file changed, 13 insertions(+), 3 deletions(-)

diff --git a/backend/package.json b/backend/package.json
index 39642d2..5259bd6 100644
--- a/backend/package.json
+++ b/backend/package.json
@@ -1,12 +1,19 @@
 {
   "name": "backend",
   "version": "1.0.0",
-  "description": "",
-  "main": "index.js",
+  "description": "IMIS — Integrated Management Information System (Express 5 + Sequelize backend)",
+  "main": "server.js",
   "scripts": {
+    "start": "node server.js",
+    "dev": "nodemon server.js",
     "test": "echo \"Error: no test specified\" && exit 1"
   },
-  "keywords": [],
+  "keywords": [
+    "imis",
+    "school-management",
+    "express",
+    "sequelize"
+  ],
   "author": "",
   "license": "ISC",
   "dependencies": {
@@ -22,5 +29,8 @@
     "sequelize": "^6.37.8",
     "sqlite3": "^5.1.7",
     "uuid": "^14.0.0"
+  },
+  "devDependencies": {
+    "nodemon": "^3.1.10"
   }
 }
